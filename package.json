    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "mqtt": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "homebridge": "^1.8.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.5.0"
  }
